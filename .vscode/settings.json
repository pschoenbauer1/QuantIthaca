{
  "editor.formatOnSave": true,
  "cmake.sourceDirectory": "${workspaceFolder}/workspace",
  "cmake.useCMakePresets": "always",
  "cmake.useVsDeveloperEnvironment": "never",
  "cmake.ignoreKitEnv": false,
  "cmake.configurePreset": "linux-gcc-debug",
  "cmake.buildPreset": "linux-gcc-debug",
  "cmake.testPreset": "linux-gcc-debug",
  "cmake.automaticReconfigure": true,
  "cmake.cmakePath": "${workspaceFolder}/workspace/.venv/bin/cmake",
  "cmake.environment": {
    "PATH": "${workspaceFolder}/workspace/.venv/bin:${env:PATH}"
  },
  "cmake.ctestArgs": [
    "-V"
  ],
  "workbench.sideBar.location": "left",
  "workbench.panel.defaultLocation": "left",
  "workbench.iconSize": "large",
  "workbench.activityBar.orientation": "vertical",
  "python.defaultInterpreterPath": "${workspaceFolder}/workspace/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "-s",
    "workspace/tests/python"
  ],
  "cmake.options.advanced": {
    "configurePreset": {
      "statusBarVisibility": "visible"
    },
    "buildPreset": {
      "statusBarVisibility": "visible"
    },
    "testPreset": {
      "statusBarVisibility": "visible"
    }
  }
}
